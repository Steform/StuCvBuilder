{% set currentLocale = currentLocale|default(app.request.locale|default('fr')) %}
{% set profilePhotoPath = cv.payload.aboutProfilePhotoDisplayPath|default('') %}
{% set hasUserProfilePhoto = cv.payload.aboutProfilePhotoHasUserUpload|default(false) %}
{% set presentationHtml = cv.payload.aboutPresentationHtml|default('') %}
{% set patternLeftSvgMarkup = cv.payload.aboutPatternLeftSvgMarkup|default('') %}
{% set patternRightSvgMarkup = cv.payload.aboutPatternRightSvgMarkup|default('') %}
{% set hasPhoto = hasUserProfilePhoto %}
{% set hasPresentation = presentationHtml|trim != '' %}
<section id="about" class="cv-about cv-public-section" aria-label="{{ 'cv.about.aria_label'|trans({}, 'messages', currentLocale) }}">
    <div class="cv-about__backdrop">
        <div class="cv-about__pattern cv-about__pattern--left">
            {% if patternLeftSvgMarkup|trim != '' %}
                {{ patternLeftSvgMarkup|raw }}
            {% endif %}
        </div>
        <div class="cv-about__pattern cv-about__pattern--right">
            {% if patternRightSvgMarkup|trim != '' %}
                {{ patternRightSvgMarkup|raw }}
            {% endif %}
        </div>
        <div class="container">
            <div class="row align-items-center g-4 g-lg-5">
                <div class="col-12 py-4 py-lg-5 col-lg-7 col-xl-8">
                    {% if hasPresentation %}
                        <article
                            class="cv-about__presentation"
                            aria-label="{{ 'cv.about.presentation_aria_label'|trans({}, 'messages', currentLocale) }}"
                        >
                            {{ presentationHtml|raw }}
                        </article>
                    {% else %}
                        <p class="cv-about__presentation-empty mb-0">{{ 'cv.placeholder.about'|trans({}, 'messages', currentLocale) }}</p>
                    {% endif %}
                </div>
                {% if hasPhoto %}
                    <div class="col-12 col-lg-5 col-xl-4">
                        <figure class="cv-about__photo-figure mb-0">
                            <img
                                class="cv-about__photo img-fluid w-100"
                                src="{{ asset(profilePhotoPath) }}"
                                alt="{{ 'cv.about.profile_photo_alt'|trans({}, 'messages', currentLocale) }}"
                                width="640"
                                height="800"
                                loading="eager"
                                decoding="async"
                            >
                        </figure>
                    </div>
                {% else %}
                    <div class="col-12 col-lg-5 col-xl-4">
                        <div class="cv-about__photo-placeholder" role="status">
                            <img
                                class="cv-about__photo-placeholder-img img-fluid"
                                src="{{ asset('images/cv/about/user-placeholder.webp') }}"
                                alt=""
                                width="320"
                                height="320"
                                loading="lazy"
                                decoding="async"
                                aria-hidden="true"
                            >
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>
