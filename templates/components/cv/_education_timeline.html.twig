{% set currentLocale = currentLocale|default(app.request.locale|default('fr')) %}
{% set educationFilter = educationFilter|default('primary') %}
{% set highlightHiddenEducations = highlightHiddenEducations|default(false) %}
{% set rawEntries = educationEntries|default(cv.payload.educationEntries|default([])) %}
{% set allEntries = rawEntries %}
{% if rawEntries.fr is defined and rawEntries.en is defined %}
    {% set allEntries = rawEntries[currentLocale]|default(rawEntries.fr|default([])) %}
{% endif %}

{% set hasTimelineEntries = false %}
{% for entry in allEntries %}
    {% if educationFilter == 'all' or (entry.isPrimary ?? true) %}
        {% set hasTimelineEntries = true %}
    {% endif %}
{% endfor %}

{% if hasTimelineEntries %}
    <div class="cv-education__timeline" role="list" aria-label="{{ 'cv.education.timeline_aria_label'|trans({}, 'messages', currentLocale) }}">
        {% set renderedEntryIds = [] %}
        {% for entry in allEntries %}
            {% set entryId = entry.id|default('') %}
            {% if entryId == '' or entryId not in renderedEntryIds %}
                {% if entryId != '' %}
                    {% set renderedEntryIds = renderedEntryIds|merge([entryId]) %}
                {% endif %}
                {% if educationFilter == 'all' or (entry.isPrimary ?? true) %}
                    {% set hasLogo = entry.institutionLogoPath|default('') != '' %}
                    {% set showInstitutionName = entry.institutionName|default('') != '' and not entry.hideInstitutionName|default(false) %}
                    {% set hasWebsite = entry.institutionWebsiteUrl|default('') != '' %}
                    {% set logoAltInstitution = entry.institutionName|default('') != '' ? entry.institutionName : entry.title|default('') %}
                    {% set hasBrand = hasLogo or showInstitutionName %}
                    {% set entryHighlights = entry.highlights|default([]) %}
                    {% set hasLocation = entry.location|default('') != '' %}
                    {% set hasExpandableDetails = hasLocation or entryHighlights|length > 0 %}
                    <article class="cv-education__timeline-item{% if highlightHiddenEducations and (entry.hiddenOnPrimary ?? false) %} cv-education__timeline-item--hidden-on-primary{% endif %}" role="listitem">
                        <div class="cv-education__timeline-marker" aria-hidden="true"></div>
                        <div class="cv-education__timeline-content">
                            {% if hasExpandableDetails %}
                                <details class="cv-education__disclosure">
                                    <summary class="cv-education__disclosure-summary">
                                        <span class="cv-education__disclosure-label cv-education__disclosure-label--expand visually-hidden">{{ 'cv.education.expand_details'|trans({}, 'messages', currentLocale) }}</span>
                                        <span class="cv-education__disclosure-label cv-education__disclosure-label--collapse visually-hidden">{{ 'cv.education.collapse_details'|trans({}, 'messages', currentLocale) }}</span>
                                        <span class="cv-education__disclosure-summary-main">
                                            {% if entry.periodLabel|default('') != '' %}
                                                <p class="cv-education__timeline-period mb-2">{{ entry.periodLabel }}</p>
                                            {% endif %}
                                            {% include 'components/cv/_education_timeline_entry_heading.html.twig' with {
                                                entry: entry,
                                                hasLogo: hasLogo,
                                                showInstitutionName: showInstitutionName,
                                                hasWebsite: hasWebsite,
                                                logoAltInstitution: logoAltInstitution,
                                                hasBrand: hasBrand,
                                                showDisclosureChevron: true,
                                                currentLocale: currentLocale
                                            } only %}
                                        </span>
                                    </summary>
                                    <div class="cv-education__disclosure-body">
                                        {% if hasLocation %}
                                            <p class="cv-education__timeline-location mb-2">{{ entry.location }}</p>
                                        {% endif %}
                                        {% if entryHighlights|length > 0 %}
                                            <ul class="cv-education__highlights mb-0 ps-3">
                                                {% for highlight in entryHighlights %}
                                                    <li>{{ highlight }}</li>
                                                {% endfor %}
                                            </ul>
                                        {% endif %}
                                    </div>
                                </details>
                            {% else %}
                                {% if entry.periodLabel|default('') != '' %}
                                    <p class="cv-education__timeline-period mb-2">{{ entry.periodLabel }}</p>
                                {% endif %}
                                {% include 'components/cv/_education_timeline_entry_heading.html.twig' with {
                                    entry: entry,
                                    hasLogo: hasLogo,
                                    showInstitutionName: showInstitutionName,
                                    hasWebsite: hasWebsite,
                                    logoAltInstitution: logoAltInstitution,
                                    hasBrand: hasBrand,
                                    currentLocale: currentLocale
                                } only %}
                            {% endif %}
                        </div>
                    </article>
                {% endif %}
            {% endif %}
        {% endfor %}
    </div>
{% else %}
    <p class="cv-education__empty text-muted mb-0">{{ 'cv.education.empty'|trans({}, 'messages', currentLocale) }}</p>
{% endif %}
