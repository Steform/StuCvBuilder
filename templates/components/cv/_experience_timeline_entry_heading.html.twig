{% set currentLocale = currentLocale|default(app.request.locale|default('fr')) %}
{% set showDisclosureChevron = showDisclosureChevron|default(false) %}
<h3 class="cv-experience__timeline-role h6 mb-0">
    {% if showDisclosureChevron %}
        <i class="bi bi-chevron-down cv-experience__disclosure-chevron" aria-hidden="true"></i>
    {% endif %}
    {% if entry.title|default('') != '' %}
        <span class="cv-experience__timeline-title">{{ entry.title }}</span>
    {% endif %}
    {% if hasBrand and entry.title|default('') != '' %}
        <span class="cv-experience__timeline-separator cv-experience__timeline-separator--brand" aria-hidden="true">·</span>
    {% endif %}
    {% if hasBrand %}
        <span class="cv-experience__company-brand">
            {% if hasLogo %}
                {% if not showCompanyName and hasWebsite %}
                    <a href="{{ entry.companyWebsiteUrl }}" class="cv-experience__company-logo-link" target="_blank" rel="noopener noreferrer">
                        <img
                            class="cv-experience__company-logo"
                            src="{{ asset(entry.companyLogoPath) }}"
                            alt="{{ 'cv.experience.company_logo_alt'|trans({'%company%': logoAltCompany}, 'messages', currentLocale) }}"
                            width="32"
                            height="32"
                            loading="lazy"
                            decoding="async"
                        >
                    </a>
                {% else %}
                    <img
                        class="cv-experience__company-logo"
                        src="{{ asset(entry.companyLogoPath) }}"
                        alt="{{ 'cv.experience.company_logo_alt'|trans({'%company%': logoAltCompany}, 'messages', currentLocale) }}"
                        width="32"
                        height="32"
                        loading="lazy"
                        decoding="async"
                    >
                {% endif %}
            {% endif %}
            {% if showCompanyName %}
                {% if hasWebsite %}
                    <a href="{{ entry.companyWebsiteUrl }}" class="cv-experience__link cv-experience__company-name" target="_blank" rel="noopener noreferrer">{{ entry.companyName }}</a>
                {% else %}
                    <span class="cv-experience__company-name">{{ entry.companyName }}</span>
                {% endif %}
            {% endif %}
        </span>
    {% endif %}
</h3>
