{% set entryId = entry.id|default('') %}
{% set educationPermalinkRoute = educationPermalinkRoute|default('admin_cv_index') %}
{% set educationPermalinkBase = educationPermalinkBaseParams|default({ tab: 'education', panel: 'education_entries' }) %}
{% set educationActiveEntry = educationActiveEntry|default('') %}
{% set educationLocale = educationLocale|default(activeLocales[0]|default('fr')) %}
{% set canonicalLocale = canonicalLocale|default(activeLocales[0]|default('fr')) %}
{% set entryDisplayIndex = displayIndex|default(1) %}
{% set entryHeadingId = 'heading-cv-education-' ~ entryId %}
{% set entryCollapseId = 'collapse-cv-education-' ~ entryId %}
{% set entryIsExpanded = educationActiveEntry != '' and educationActiveEntry == entryId %}
{% set dashboardLocale = currentLocale|default(activeLocales[0]|default('fr')) %}
{% set accordionTitle = '' %}
{% if dashboardLocale in activeLocales|default(['fr']) %}
    {% for candidate in entriesByLocale[dashboardLocale]|default([]) %}
        {% if candidate.id|default('') == entryId %}
            {% set accordionTitle = candidate.title|default('') %}
        {% endif %}
    {% endfor %}
{% else %}
    {% for candidate in entriesByLocale[canonicalLocale]|default([]) %}
        {% if candidate.id|default('') == entryId and candidate.title|default('') != '' %}
            {% set accordionTitle = candidate.title %}
        {% endif %}
    {% endfor %}
    {% if accordionTitle == '' %}
        {% for locale in activeLocales|default(['fr']) %}
            {% if accordionTitle == '' %}
                {% for candidate in entriesByLocale[locale]|default([]) %}
                    {% if candidate.id|default('') == entryId and candidate.title|default('') != '' %}
                        {% set accordionTitle = candidate.title %}
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% endfor %}
    {% endif %}
{% endif %}
{% set entryAccordionLabel = accordionTitle != ''
    ? accordionTitle
    : 'dashboard.customization_cv.education.entry_title'|trans({'%index%': entryDisplayIndex}, 'messages', currentLocale) %}
{% set entryAccordionMeta = [] %}
{% if entry.institutionName|default('') != '' and not entry.hideInstitutionName|default(false) %}
    {% set entryAccordionMeta = entryAccordionMeta|merge([entry.institutionName]) %}
{% endif %}
{% if entry.periodLabel|default('') != '' %}
    {% set entryAccordionMeta = entryAccordionMeta|merge([entry.periodLabel]) %}
{% elseif entry.startDate|default('') != '' %}
    {% if entry.isCurrent|default(false) %}
        {% set entryAccordionMeta = entryAccordionMeta|merge([entry.startDate ~ ' – ' ~ ('dashboard.customization_cv.education.period_present'|trans({}, 'messages', currentLocale))]) %}
    {% elseif entry.endDate|default('') != '' %}
        {% set entryAccordionMeta = entryAccordionMeta|merge([entry.startDate ~ ' – ' ~ entry.endDate]) %}
    {% else %}
        {% set entryAccordionMeta = entryAccordionMeta|merge([entry.startDate]) %}
    {% endif %}
{% endif %}
<div
    class="accordion-item cv-education-customization__entry"
    data-cv-education-entry
    data-customization-entry="{{ entryId }}"
>
    <h3 class="accordion-header cv-education-customization__entry-header" id="{{ entryHeadingId }}">
        <div class="cv-education-customization__entry-header-row">
            <div class="cv-education-customization__entry-header-title">
                <span class="cv-education-customization__entry-summary" data-cv-education-entry-summary>
                    <span class="cv-education-customization__entry-summary-title" data-cv-education-entry-summary-title>{{ entryAccordionLabel }}</span>
                    {% if entryAccordionMeta|length > 0 %}
                        <span class="cv-education-customization__entry-summary-meta text-muted small" data-cv-education-entry-summary-meta>{{ entryAccordionMeta|join(' · ') }}</span>
                    {% else %}
                        <span class="cv-education-customization__entry-summary-meta text-muted small d-none" data-cv-education-entry-summary-meta></span>
                    {% endif %}
                </span>
            </div>
            <div class="cv-education-customization__entry-header-actions">
                <div
                    class="btn-group btn-group-sm"
                    role="group"
                    aria-label="{{ 'dashboard.customization_cv.education.entry_actions_aria'|trans({}, 'messages', currentLocale) }}"
                >
                    <button type="button" class="btn btn-outline-secondary" data-cv-education-move="up" title="{{ 'dashboard.customization_cv.education.move_up'|trans({}, 'messages', currentLocale) }}">
                        <span class="visually-hidden">{{ 'dashboard.customization_cv.education.move_up'|trans({}, 'messages', currentLocale) }}</span>
                        &uarr;
                    </button>
                    <button type="button" class="btn btn-outline-secondary" data-cv-education-move="down" title="{{ 'dashboard.customization_cv.education.move_down'|trans({}, 'messages', currentLocale) }}">
                        <span class="visually-hidden">{{ 'dashboard.customization_cv.education.move_down'|trans({}, 'messages', currentLocale) }}</span>
                        &darr;
                    </button>
                    <button type="button" class="btn btn-outline-danger" data-cv-education-remove>
                        {{ 'dashboard.customization_cv.education.remove_entry'|trans({}, 'messages', currentLocale) }}
                    </button>
                </div>
                <a
                    class="cv-education-customization__entry-accordion-toggle accordion-button{% if not entryIsExpanded %} collapsed{% endif %}"
                    href="{{ path(educationPermalinkRoute, educationPermalinkBase|merge({ locale: educationLocale, entry: entryId })) }}"
                    role="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#{{ entryCollapseId }}"
                    aria-expanded="{{ entryIsExpanded ? 'true' : 'false' }}"
                    aria-controls="{{ entryCollapseId }}"
                    data-cv-education-entry-toggle
                    aria-label="{{ 'dashboard.customization_cv.education.toggle_entry_aria'|trans({}, 'messages', currentLocale) }}"
                >
                    <span class="visually-hidden">{{ 'dashboard.customization_cv.education.toggle_entry_aria'|trans({}, 'messages', currentLocale) }}</span>
                </a>
            </div>
        </div>
    </h3>
    <div
        id="{{ entryCollapseId }}"
        class="accordion-collapse collapse{% if entryIsExpanded %} show{% endif %}"
        data-cv-education-entry-collapse="{{ entryId }}"
        aria-labelledby="{{ entryHeadingId }}"
        data-bs-parent="#cvEducationEntriesAccordion"
    >
        <div class="accordion-body">
            {% include 'components/cv/admin/_education_entry_shared_fields.html.twig' with {
                entry: entry,
                entryId: entryId,
                canonicalLocale: canonicalLocale,
                canonicalIndex: canonicalIndex,
                currentLocale: currentLocale
            } only %}

            <p class="form-text mb-2">{{ 'dashboard.customization_cv.education.entry_locale_tabs_help'|trans({}, 'messages', currentLocale) }}</p>

            <ul
                class="nav nav-tabs flex-wrap gap-1 mb-3"
                id="cvEducationEntryLocaleTabs-{{ entryId }}"
                role="tablist"
                data-cv-education-entry-locale-tabs
                data-entry-id="{{ entryId }}"
            >
                {% for locale in activeLocales|default(['fr']) %}
                    <li class="nav-item" role="presentation">
                        <button
                            class="nav-link{% if locale == educationLocale and entryIsExpanded %} active{% endif %}"
                            type="button"
                            role="tab"
                            data-bs-toggle="tab"
                            data-bs-target="#cv-education-entry-{{ entryId }}-locale-{{ locale }}"
                            data-cv-education-entry-locale-tab="{{ locale }}"
                            data-customization-locale-tab="{{ locale }}"
                            data-cv-education-entry-locale-permalink="{{ path(educationPermalinkRoute, educationPermalinkBase|merge({ locale: locale, entry: entryId })) }}"
                            aria-controls="cv-education-entry-{{ entryId }}-locale-{{ locale }}"
                            aria-selected="{{ locale == educationLocale and entryIsExpanded ? 'true' : 'false' }}"
                        >
                            {{ 'dashboard.customization_cv.education.locale_tab_label'|trans({'%code%': locale|upper}, 'messages', currentLocale) }}
                        </button>
                    </li>
                {% endfor %}
            </ul>

            <div class="tab-content" id="cvEducationEntryLocaleTabContent-{{ entryId }}">
                {% for locale in activeLocales|default(['fr']) %}
                    {% set localeEntry = null %}
                    {% set localeIndex = canonicalIndex %}
                    {% for candidate in entriesByLocale[locale]|default([]) %}
                        {% if candidate.id|default('') == entryId %}
                            {% set localeEntry = candidate %}
                            {% set localeIndex = loop.index0 %}
                        {% endif %}
                    {% endfor %}
                    {% set paneEntry = localeEntry ?? entry %}
                    <div
                        class="tab-pane fade{% if locale == educationLocale and entryIsExpanded %} show active{% endif %}"
                        id="cv-education-entry-{{ entryId }}-locale-{{ locale }}"
                        role="tabpanel"
                        data-cv-education-entry-locale-pane
                        data-locale="{{ locale }}"
                        data-entry-id="{{ entryId }}"
                    >
                        {% include 'components/cv/admin/_education_entry_locale_fields.html.twig' with {
                            locale: locale,
                            index: localeIndex,
                            entryId: entryId,
                            entry: paneEntry,
                            currentLocale: currentLocale
                        } only %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
