{% set entries = cvInterestsEntries|default([]) %}
{% set interestsPanel = cvCustomizationActivePanel|default('section') %}
{% set interestsLocale = cvCustomizationActiveLocale|default(activeLocales[0]|default('fr')) %}
{% set selectedTexture = cvSectionBackgrounds.interests.texture|default(cvInterestsBackgroundTexture|default('texture_1')) %}
{% set interestsFormAction = cvInterestsFormAction|default(path('admin_cv_index')) %}
{% set interestsFormScope = cvInterestsFormScope|default('interests') %}
{% set summaryLocale = defaultLocale|default(activeLocales[0]|default('fr')) %}
{% set interestsI18n = {
    entryTitleAdd: 'dashboard.customization_cv.interests.modal.entry_title_add'|trans({}, 'messages', currentLocale),
    entryTitleEdit: 'dashboard.customization_cv.interests.modal.entry_title_edit'|trans({}, 'messages', currentLocale),
    entryFallback: 'dashboard.customization_cv.interests.entry_title'|trans({'%index%': '__INDEX__'}, 'messages', currentLocale),
    confirmDelete: 'dashboard.customization_cv.interests.modal.confirm_delete'|trans({}, 'messages', currentLocale),
    flashError: 'dashboard.customization_cv.flash.interests_invalid'|trans({}, 'messages', currentLocale),
    flashInvalidBootstrapIcon: 'dashboard.customization_cv.interests.flash_invalid_bootstrap_icon'|trans({}, 'messages', currentLocale),
    flashInvalidIcon: 'dashboard.customization_cv.interests.flash_invalid_icon'|trans({}, 'messages', currentLocale),
    iconFileRequired: 'dashboard.customization_cv.interests.modal.icon_file_required'|trans({}, 'messages', currentLocale),
    labelRequired: 'dashboard.customization_cv.interests.modal.label_required'|trans({}, 'messages', currentLocale),
    removeEntry: 'dashboard.customization_cv.interests.remove_entry'|trans({}, 'messages', currentLocale),
    moveUpAria: 'dashboard.customization_cv.interests.modal.move_up_aria'|trans({}, 'messages', currentLocale),
    moveDownAria: 'dashboard.customization_cv.interests.modal.move_down_aria'|trans({}, 'messages', currentLocale),
    bootstrapIconBrowserCount: 'dashboard.customization_cv.shared.bootstrap_icon_browser_count'|trans({}, 'messages', currentLocale)
} %}
<script type="application/json" id="cv-interests-entries-data">{{ entries|json_encode|raw }}</script>
<div
    class="cv-interests-customization"
    data-cv-interests-admin
    data-active-locales="{{ activeLocales|default(['fr'])|json_encode|e('html_attr') }}"
    data-default-locale="{{ summaryLocale|e('html_attr') }}"
    data-i18n="{{ interestsI18n|json_encode|e('html_attr') }}"
    data-bootstrap-icons-manifest-url="{{ cv_skills_bootstrap_icon_manifest_url()|e('html_attr') }}"
>
    <div class="accordion mb-3" id="cvInterestsCustomizationAccordion">
        {% if not cvInterestsHideSectionCustomization|default(false) %}
        <div class="accordion-item" data-customization-panel="section">
            <h2 class="accordion-header" id="headingInterestsAccordionSection">
                <a
                    class="accordion-button{% if interestsPanel != 'section' %} collapsed{% endif %}"
                    href="{{ path('admin_cv_index', { tab: 'interests', panel: 'section', locale: interestsLocale }) }}"
                    role="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#collapseInterestsAccordionSection"
                    aria-expanded="{{ interestsPanel == 'section' ? 'true' : 'false' }}"
                    aria-controls="collapseInterestsAccordionSection"
                >
                    {{ 'dashboard.customization_cv.interests_accordion.section_customization_title'|trans({}, 'messages', currentLocale) }}
                </a>
            </h2>
            <div
                id="collapseInterestsAccordionSection"
                class="accordion-collapse collapse{% if interestsPanel == 'section' %} show{% endif %}"
                data-customization-panel-collapse="section"
                aria-labelledby="headingInterestsAccordionSection"
                data-bs-parent="#cvInterestsCustomizationAccordion"
            >
                <div class="accordion-body">
                    <p class="form-text mb-3">{{ 'dashboard.customization_cv.interests_accordion.section_customization_help'|trans({}, 'messages', currentLocale) }}</p>
                    <form method="post" action="{{ path('admin_cv_index') }}" class="mb-0">
                        <input type="hidden" name="form_scope" value="interests_layout">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_cv_interests_layout') }}">
                        <input type="hidden" name="customization_tab" value="interests">
                        <input type="hidden" name="customization_panel" value="section">
                        {% include 'components/cv/admin/_interests_layout_field.html.twig' with {
                            currentLocale: currentLocale,
                            cvInterestsColumnsPerRow: cvInterestsColumnsPerRow|default(4),
                            cvInterestsColumnsPerRowSmall: cvInterestsColumnsPerRowSmall|default(2)
                        } only %}
                        <button type="submit" class="btn btn-primary mt-3">{{ 'dashboard.customization_cv.interests.layout_save'|trans({}, 'messages', currentLocale) }}</button>
                    </form>
                    <form method="post" action="{{ path('admin_cv_index') }}" class="cv-section-customization__background-form mt-4 pt-4 border-top mb-0">
                        <input type="hidden" name="form_scope" value="interests_background">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_cv_interests_background') }}">
                        <input type="hidden" name="customization_tab" value="interests">
                        <input type="hidden" name="customization_panel" value="section">
                        {% include 'components/cv/admin/_interests_section_tone_fields.html.twig' with { cvSectionBackgrounds: cvSectionBackgrounds|default({}), currentLocale: currentLocale } only %}
                        <button type="submit" class="btn btn-primary mt-3">{{ 'dashboard.customization_cv.section_background.save'|trans({}, 'messages', currentLocale) }}</button>
                    </form>
                </div>
            </div>
        </div>
        {% endif %}
        <div class="accordion-item" data-customization-panel="interests_entries">
            <h2 class="accordion-header" id="headingInterestsAccordionEntries">
                <a
                    class="accordion-button{% if interestsPanel != 'interests_entries' %} collapsed{% endif %}"
                    href="{{ path('admin_cv_index', { tab: 'interests', panel: 'interests_entries', locale: interestsLocale }) }}"
                    role="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#collapseInterestsAccordionEntries"
                    aria-expanded="{{ interestsPanel == 'interests_entries' ? 'true' : 'false' }}"
                    aria-controls="collapseInterestsAccordionEntries"
                >
                    {{ 'dashboard.customization_cv.interests_accordion.entries_title'|trans({}, 'messages', currentLocale) }}
                </a>
            </h2>
            <div
                id="collapseInterestsAccordionEntries"
                class="accordion-collapse collapse{% if interestsPanel == 'interests_entries' %} show{% endif %}"
                data-customization-panel-collapse="interests_entries"
                aria-labelledby="headingInterestsAccordionEntries"
                data-bs-parent="#cvInterestsCustomizationAccordion"
            >
                <div class="accordion-body">
                    <p class="text-muted small">{{ 'dashboard.customization_cv.interests_accordion.entries_help'|trans({}, 'messages', currentLocale) }}</p>
                    <form method="post" action="{{ interestsFormAction }}" class="cv-interests-customization__form">
                        <input type="hidden" name="form_scope" value="{{ interestsFormScope }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token(cvInterestsCsrfTokenId|default('admin_cv_interests')) }}">
                        {% if interestsFormScope == 'interests' %}<input type="hidden" name="customization_tab" value="interests">{% endif %}
                        {% if cvInterestsCustomizationSection is defined and cvInterestsCustomizationSection %}<input type="hidden" name="customization_section" value="{{ cvInterestsCustomizationSection }}">{% endif %}
                        <input type="hidden" name="customization_panel" value="interests_entries">
                        {% if cvInterestsHideSectionCustomization|default(false) %}
                            <div class="mb-4 pb-3 border-bottom">
                                {% include 'components/cv/admin/_interests_layout_field.html.twig' with {
                                    currentLocale: currentLocale,
                                    cvInterestsColumnsPerRow: cvInterestsColumnsPerRow|default(4),
                                    cvInterestsColumnsPerRowSmall: cvInterestsColumnsPerRowSmall|default(2)
                                } only %}
                            </div>
                        {% endif %}
                        <div class="d-none" data-cv-interests-entries-storage aria-hidden="true"></div>
                        <ul class="list-group mb-3" data-cv-interests-list></ul>
                        <p class="text-muted small{% if entries is not empty %} d-none{% endif %}" data-cv-interests-list-empty>
                            {{ 'dashboard.customization_cv.interests.list_empty'|trans({}, 'messages', currentLocale) }}
                        </p>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <button type="button" class="btn btn-sm btn-outline-primary" data-cv-interests-add>
                                {{ 'dashboard.customization_cv.interests.add_entry'|trans({}, 'messages', currentLocale) }}
                            </button>
                        </div>
                        <button type="submit" class="btn btn-primary">{{ 'dashboard.customization_cv.interests.save'|trans({}, 'messages', currentLocale) }}</button>
                    </form>
                    <hr class="my-4">
                    <h3 class="h6 mb-2">{{ 'dashboard.customization_cv.interests.preview_title'|trans({}, 'messages', currentLocale) }}</h3>
                    <div class="cv-interests-customization__preview" data-cv-interests-preview aria-live="polite">
                        {% set previewEntries = cvInterestsPreviewEntries|default(entries) %}
                        {% include 'components/cv/_interests.html.twig' with { cv: { payload: { interestEntries: previewEntries, interestsBackgroundTexture: selectedTexture, interestsColumnsPerRow: cvInterestsColumnsPerRow|default(4), interestsColumnsPerRowSmall: cvInterestsColumnsPerRowSmall|default(2) } }, currentLocale: currentLocale } only %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% include 'components/cv/admin/_interests_entry_modal.html.twig' with {
        currentLocale: currentLocale,
        activeLocales: activeLocales|default(['fr']),
        defaultLocale: summaryLocale
    } only %}
    {% include 'components/cv/admin/_bootstrap_icon_browser_modal.html.twig' with {
        currentLocale: currentLocale,
        bootstrapIconBrowserModalId: 'cvInterestsBootstrapIconBrowserModal'
    } only %}
</div>
