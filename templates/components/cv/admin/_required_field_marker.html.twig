{% set suffixKey = requiredFieldSuffixKey|default('dashboard.customization_cv.shared.required_field_suffix') %}
{% set showAccessibleSuffix = showAccessibleSuffix|default(true) %}
<span class="text-danger" aria-hidden="true">*</span>
{% if showAccessibleSuffix %}
    <span class="visually-hidden">{{ suffixKey|trans({}, 'messages', currentLocale) }}</span>
{% endif %}
