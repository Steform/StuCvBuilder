{# Admin CRUD for custom home quick tiles (embedded in home customization accordion). #}
{% set currentLocale = app.request.locale|default('fr') %}
{% set homeCustomizationPanelUrl = path('app_dashboard_customization_home', {panel: 'custom_quick_tiles'}) %}

<div class="row g-4">
    <div class="col-12 col-xl-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h6 mb-3">
                    {% if editTile %}
                        {{ 'dashboard.customization_quick_tiles.form_edit_title'|trans({}, 'messages', currentLocale) }}
                    {% else %}
                        {{ 'dashboard.customization_quick_tiles.form_create_title'|trans({}, 'messages', currentLocale) }}
                    {% endif %}
                </h2>
                <form
                    method="post"
                    action="{{ path('app_dashboard_customization_quick_tiles') }}"
                    enctype="multipart/form-data"
                >
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('dashboard_customization_quick_tiles') }}">
                    <input type="hidden" name="action" value="{{ editTile ? 'update' : 'create' }}">
                    {% if editTile %}
                        <input type="hidden" name="tile_id" value="{{ editTile.id }}">
                    {% endif %}

                    <div class="mb-3">
                        <label class="form-label" for="quick-tile-link">{{ 'dashboard.customization_quick_tiles.fields.link'|trans({}, 'messages', currentLocale) }}</label>
                        <input
                            class="form-control"
                            id="quick-tile-link"
                            name="link_url"
                            type="text"
                            value="{{ editTile ? editTile.linkUrl : '' }}"
                            required
                        >
                        <div class="form-text">{{ 'dashboard.customization_quick_tiles.fields.link_help'|trans({}, 'messages', currentLocale) }}</div>
                    </div>

                    <div class="mb-3 form-check">
                        <input
                            class="form-check-input"
                            type="checkbox"
                            id="quick-tile-new-tab"
                            name="open_in_new_tab"
                            value="1"
                            {{ editTile and editTile.openInNewTab ? 'checked' : '' }}
                        >
                        <label class="form-check-label" for="quick-tile-new-tab">{{ 'dashboard.customization_quick_tiles.fields.open_new_tab'|trans({}, 'messages', currentLocale) }}</label>
                    </div>

                    {% if editTile %}
                        <div class="mb-3 form-check">
                            <input
                                class="form-check-input"
                                type="checkbox"
                                id="quick-tile-enabled"
                                name="enabled"
                                value="1"
                                {{ editTile.enabled ? 'checked' : '' }}
                            >
                            <label class="form-check-label" for="quick-tile-enabled">{{ 'dashboard.customization_quick_tiles.fields.enabled'|trans({}, 'messages', currentLocale) }}</label>
                        </div>
                    {% endif %}

                    <div class="mb-3">
                        <label class="form-label" for="quick-tile-icon">{{ 'dashboard.customization_quick_tiles.fields.icon'|trans({}, 'messages', currentLocale) }}</label>
                        <input
                            class="form-control"
                            id="quick-tile-icon"
                            name="tile_icon_upload"
                            type="file"
                            accept="image/svg+xml,image/webp"
                            {{ editTile ? '' : 'required' }}
                        >
                        <div class="form-text">{{ 'dashboard.customization_quick_tiles.fields.icon_help'|trans({}, 'messages', currentLocale) }}</div>
                        {% if editTile and editTile.iconRelativePath %}
                            <img
                                class="quick-tiles-admin__preview mt-2"
                                src="{{ asset(editTile.iconRelativePath) }}"
                                alt=""
                                width="80"
                                height="80"
                            >
                        {% endif %}
                    </div>

                    <p class="form-text mb-3">{{ 'dashboard.customization_quick_tiles.fields.labels_help'|trans({}, 'messages', currentLocale) }}</p>
                    <ul class="nav nav-tabs mb-3" role="tablist">
                        {% for localeCode in activeLocales %}
                            <li class="nav-item" role="presentation">
                                <button
                                    class="nav-link{% if localeCode == defaultLocale %} active{% endif %}"
                                    id="admin-quick-tile-tab-{{ localeCode }}"
                                    data-bs-toggle="tab"
                                    data-bs-target="#admin-quick-tile-pane-{{ localeCode }}"
                                    type="button"
                                    role="tab"
                                >{{ localeCode|upper }}</button>
                            </li>
                        {% endfor %}
                    </ul>
                    <div class="tab-content mb-3">
                        {% for localeCode in activeLocales %}
                            <div
                                class="tab-pane fade{% if localeCode == defaultLocale %} show active{% endif %}"
                                id="admin-quick-tile-pane-{{ localeCode }}"
                                role="tabpanel"
                            >
                                <label class="form-label" for="quick-tile-label-{{ localeCode }}">
                                    {{ 'dashboard.customization_quick_tiles.fields.label_locale'|trans({'%locale%': localeCode|upper}, 'messages', currentLocale) }}
                                </label>
                                <input
                                    class="form-control"
                                    id="quick-tile-label-{{ localeCode }}"
                                    name="tile_label[{{ localeCode }}]"
                                    type="text"
                                    maxlength="128"
                                    value="{{ editTile ? editTile.labelForLocale(localeCode) : '' }}"
                                >
                            </div>
                        {% endfor %}
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-primary">
                            {% if editTile %}
                                {{ 'dashboard.customization_quick_tiles.actions.save'|trans({}, 'messages', currentLocale) }}
                            {% else %}
                                {{ 'dashboard.customization_quick_tiles.actions.create'|trans({}, 'messages', currentLocale) }}
                            {% endif %}
                        </button>
                        {% if editTile %}
                            <a class="btn btn-outline-secondary" href="{{ homeCustomizationPanelUrl }}">
                                {{ 'dashboard.customization_quick_tiles.actions.cancel_edit'|trans({}, 'messages', currentLocale) }}
                            </a>
                        {% endif %}
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h6 mb-3">{{ 'dashboard.customization_quick_tiles.list_title'|trans({}, 'messages', currentLocale) }}</h2>
                {% if tiles is empty %}
                    <p class="text-muted mb-0">{{ 'dashboard.customization_quick_tiles.list_empty'|trans({}, 'messages', currentLocale) }}</p>
                {% else %}
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                            <tr>
                                <th>{{ 'dashboard.customization_quick_tiles.table.preview'|trans({}, 'messages', currentLocale) }}</th>
                                <th>{{ 'dashboard.customization_quick_tiles.table.labels'|trans({}, 'messages', currentLocale) }}</th>
                                <th>{{ 'dashboard.customization_quick_tiles.table.link'|trans({}, 'messages', currentLocale) }}</th>
                                <th>{{ 'dashboard.customization_quick_tiles.table.status'|trans({}, 'messages', currentLocale) }}</th>
                                <th class="text-end">{{ 'dashboard.customization_quick_tiles.table.actions'|trans({}, 'messages', currentLocale) }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for tile in tiles %}
                                <tr>
                                    <td>
                                        {% if tile.iconRelativePath %}
                                            <img src="{{ asset(tile.iconRelativePath) }}" alt="" class="quick-tiles-admin__preview" width="48" height="48">
                                        {% endif %}
                                    </td>
                                    <td>
                                        <ul class="list-unstyled mb-0 small">
                                            {% for translation in tile.translations %}
                                                <li><strong>{{ translation.locale|upper }}:</strong> {{ translation.label }}</li>
                                            {% endfor %}
                                        </ul>
                                    </td>
                                    <td class="small text-break">{{ tile.linkUrl }}</td>
                                    <td>
                                        {% if tile.enabled %}
                                            <span class="badge text-bg-success">{{ 'dashboard.customization_quick_tiles.status.enabled'|trans({}, 'messages', currentLocale) }}</span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">{{ 'dashboard.customization_quick_tiles.status.disabled'|trans({}, 'messages', currentLocale) }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex flex-wrap gap-1 justify-content-end">
                                            <a class="btn btn-outline-primary btn-sm" href="{{ path('app_dashboard_customization_home', {panel: 'custom_quick_tiles', edit: tile.id}) }}">{{ 'dashboard.customization_quick_tiles.actions.edit'|trans({}, 'messages', currentLocale) }}</a>
                                            <form method="post" action="{{ path('app_dashboard_customization_quick_tiles') }}" class="d-inline">
                                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('dashboard_customization_quick_tiles') }}">
                                                <input type="hidden" name="action" value="move_up">
                                                <input type="hidden" name="tile_id" value="{{ tile.id }}">
                                                <button type="submit" class="btn btn-outline-secondary btn-sm">{{ 'dashboard.customization_quick_tiles.actions.move_up'|trans({}, 'messages', currentLocale) }}</button>
                                            </form>
                                            <form method="post" action="{{ path('app_dashboard_customization_quick_tiles') }}" class="d-inline">
                                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('dashboard_customization_quick_tiles') }}">
                                                <input type="hidden" name="action" value="move_down">
                                                <input type="hidden" name="tile_id" value="{{ tile.id }}">
                                                <button type="submit" class="btn btn-outline-secondary btn-sm">{{ 'dashboard.customization_quick_tiles.actions.move_down'|trans({}, 'messages', currentLocale) }}</button>
                                            </form>
                                            <form method="post" action="{{ path('app_dashboard_customization_quick_tiles') }}" class="d-inline" onsubmit="return confirm('{{ 'dashboard.customization_quick_tiles.actions.confirm_delete'|trans({}, 'messages', currentLocale)|e('js') }}');">
                                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('dashboard_customization_quick_tiles') }}">
                                                <input type="hidden" name="action" value="delete">
                                                <input type="hidden" name="tile_id" value="{{ tile.id }}">
                                                <button type="submit" class="btn btn-outline-danger btn-sm">{{ 'dashboard.customization_quick_tiles.actions.delete'|trans({}, 'messages', currentLocale) }}</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
