<!doctype html>
<html lang="{{ locale|default('fr') }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ labels.field_subject|default('mail.cv_contact.field_subject'|trans({}, 'messages', locale|default('fr'))) }}</title>
</head>
<body style="margin:0; padding:0; background-color:#f8f9fa;">
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f8f9fa; margin:0; padding:24px 0;">
    <tr>
        <td align="center" style="padding:0 12px;">
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:640px;">
                <tr>
                    <td style="background-color:#ffffff; border:1px solid #dee2e6; border-radius:8px; padding:28px 24px;">
                        <p style="font-family:Arial, Helvetica, sans-serif; font-size:16px; line-height:24px; color:#212529; margin:0 0 12px 0;">
                            {{ blocks.intro|default('')|raw }}
                        </p>
                        <p style="font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:22px; color:#212529; margin:0 0 8px 0;">
                            <strong>{{ labels.field_name|default('mail.cv_contact.field_name'|trans({}, 'messages', locale|default('fr'))) }}:</strong>
                            {{ visitorName }}
                        </p>
                        <p style="font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:22px; color:#212529; margin:0 0 8px 0;">
                            <strong>{{ labels.field_email|default('mail.cv_contact.field_email'|trans({}, 'messages', locale|default('fr'))) }}:</strong>
                            {{ visitorEmail }}
                        </p>
                        <p style="font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:22px; color:#212529; margin:0 0 16px 0;">
                            <strong>{{ labels.field_subject|default('mail.cv_contact.field_subject'|trans({}, 'messages', locale|default('fr'))) }}:</strong>
                            {{ subjectLine }}
                        </p>
                        <p style="font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:22px; color:#212529; margin:0 0 8px 0;">
                            <strong>{{ labels.field_message|default('mail.cv_contact.field_message'|trans({}, 'messages', locale|default('fr'))) }}:</strong>
                        </p>
                        <p style="font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:22px; color:#212529; margin:0; white-space:pre-wrap;">{{ messageBody }}</p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>
