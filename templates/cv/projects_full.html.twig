{% extends 'base.html.twig' %}
{% set currentLocale = currentLocale|default(app.request.locale|default('fr')) %}
{% set seoSectionTranslationKey = 'cv.projects.full_page_meta_title' %}
{% set seoDescription = site_seo_cv_meta_description(currentLocale, 'cv.meta.description', seoSectionTranslationKey) %}
{% set flagshipProjectsFull = flagshipProjectsFull|default(cv.payload.flagshipProjectsFull|default([])) %}

{% block title %}{{ site_seo_cv_page_title(currentLocale, seoSectionTranslationKey) }}{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('css/cv-public-layout.css') }}" rel="stylesheet">
    {% set siteColorsLayoutCssVersion = cv.siteColorsLayoutCssCacheSuffix|default('0') %}
    <link href="{{ path('app_cv_public_sidebar_css', { v: siteColorsLayoutCssVersion }) }}" rel="stylesheet">
    <link href="{{ asset('css/cv-about-public.css') }}" rel="stylesheet">
    {% set aboutPatternCssVersion = cv.aboutPatternCssCacheSuffix|default('0') %}
    <link href="{{ path('app_cv_about_pattern_css', { v: aboutPatternCssVersion }) }}" rel="stylesheet">
    <link href="{{ asset('css/cv-public-sections.css') }}" rel="stylesheet">
    <link href="{{ asset('css/cv-contact-modal.css') }}" rel="stylesheet">
{% endblock %}

{% block top_navigation %}{% endblock %}

{% block main_container_class %}container-fluid p-0{% endblock %}

{% block body %}
    {% embed 'components/cv/_cv_public_shell.html.twig' with {
        currentLocale: currentLocale,
        cv: cv,
        flagshipProjectsFull: flagshipProjectsFull
    } only %}
        {% block cv_public_main %}
            <section id="projects-full" class="cv-projects cv-public-section py-5" aria-labelledby="cv-projects-full-title">
                <div class="container">
                    <header class="cv-projects-full__header mb-4">
                        <div class="d-flex align-items-center gap-3">
                            <a
                                class="cv-projects-full__back-btn"
                                href="{{ path('cv_show', app.request.query.has('format') ? { format: app.request.query.get('format') } : {}) }}#projects"
                                aria-label="{{ 'cv.projects.back_to_cv'|trans({}, 'messages', currentLocale) }}"
                            >
                                <i class="bi bi-arrow-left cv-projects-full__back-icon" aria-hidden="true"></i>
                            </a>
                            <h1 id="cv-projects-full-title" class="cv-public-section__title h3 mb-0">
                                {{ 'cv.projects.full_page_title'|trans({}, 'messages', currentLocale) }}
                            </h1>
                        </div>
                    </header>

                    <p class="cv-projects__full-legend text-muted small mb-4">
                        {{ 'cv.projects.full_page_highlight_legend'|trans({}, 'messages', currentLocale) }}
                    </p>

                    {% if flagshipProjectsFull|length > 0 %}
                        <div
                            class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4"
                            role="list"
                            aria-label="{{ 'cv.projects.grid_aria_label'|trans({}, 'messages', currentLocale) }}"
                        >
                            {% for project in flagshipProjectsFull %}
                                <div class="col" role="listitem">
                                    {% include 'components/cv/_flagship_project_card.html.twig' with {
                                        project: project,
                                        currentLocale: currentLocale,
                                        highlightHiddenProjects: true
                                    } only %}
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="mb-0 text-muted">{{ 'cv.projects.empty'|trans({}, 'messages', currentLocale) }}</p>
                    {% endif %}
                </div>
            </section>
        {% endblock %}
    {% endembed %}
    {% include 'components/cv/_contact_modal.html.twig' with { currentLocale: currentLocale } only %}
{% endblock %}

{% block extra_scripts %}
    {{ parent() }}
    <script src="{{ asset('js/cv-public-nav.js') }}" defer></script>
    <script src="{{ asset('js/cv-contact-modal.js') }}" defer></script>
    <script src="{{ asset('js/cv-projects-tags.js') }}" defer></script>
{% endblock %}
