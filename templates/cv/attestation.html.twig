{% extends 'base.html.twig' %}
{% set currentLocale = currentLocale|default(app.request.locale|default('fr')) %}
{% set seoRobots = 'noindex, nofollow' %}

{% block title %}{{ 'cv.antibot.attestation_title'|trans({}, 'messages', currentLocale) }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('css/cv-attestation.css') }}" rel="stylesheet">
{% endblock %}

{% block main_container_class %}container py-5{% endblock %}

{% block floating_actions %}{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card shadow-sm cv-attestation-card">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3">{{ 'cv.antibot.attestation_title'|trans({}, 'messages', currentLocale) }}</h1>
                    <p class="text-muted mb-4">{{ 'cv.antibot.attestation_intro'|trans({}, 'messages', currentLocale) }}</p>

                    {% include 'components/_flash_messages.html.twig' %}

                    <form method="post" action="{{ path('cv_attestation_submit') }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('cv_attestation') }}">
                        <input type="hidden" name="return_to" value="{{ returnTo }}">
                        {% include 'components/security/_captcha_challenge.html.twig' %}
                        <button type="submit" class="btn btn-primary w-100 mt-2">
                            {{ 'cv.antibot.attestation_submit'|trans({}, 'messages', currentLocale) }}
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block extra_scripts %}
    <script src="{{ asset('js/cv-attestation.js') }}" defer></script>
{% endblock %}
