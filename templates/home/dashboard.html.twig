{% extends 'base.html.twig' %}
{% set currentLocale = app.request.locale|default('fr') %}

{% block title %}{{ 'dashboard.meta.title'|trans({}, 'messages', currentLocale) }}{% endblock %}

{% block flash_messages %}{% endblock %}

{% block top_navigation %}
    {% include 'components/_admin_dashboard_menu.html.twig' %}
{% endblock %}

{% block floating_actions %}
    {{ parent() }}
{% endblock %}

{% block main_container_class %}container py-4{% endblock %}

{% block body %}
    {% if maintenanceModeEnabled|default(false) %}
        <div class="alert alert-warning d-flex align-items-start gap-2 mb-4" role="status">
            <i class="bi bi-tools flex-shrink-0 mt-1" aria-hidden="true"></i>
            <div>
                <strong>{{ 'dashboard.maintenance_banner.title'|trans({}, 'messages', currentLocale) }}</strong>
                <p class="mb-2 small">{{ 'dashboard.maintenance_banner.description'|trans({}, 'messages', currentLocale) }}</p>
                <a class="btn btn-sm btn-outline-dark" href="{{ path('app_dashboard_configuration_site') }}">
                    {{ 'dashboard.maintenance_banner.action'|trans({}, 'messages', currentLocale) }}
                </a>
            </div>
        </div>
    {% endif %}

    {% include 'components/admin/_setup_onboarding_checklist.html.twig' with {
        setupOnboarding: setupOnboarding|default(null),
        currentLocale: currentLocale,
    } only %}

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h1 class="h4 mb-3">{{ 'dashboard.title'|trans({}, 'messages', currentLocale) }}</h1>
            <p class="mb-0">{{ 'dashboard.description'|trans({}, 'messages', currentLocale) }}</p>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
        <div class="col">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h2 class="h6">{{ 'dashboard.cards.cv_title'|trans({}, 'messages', currentLocale) }}</h2>
                    <p class="text-muted small flex-grow-1">{{ 'dashboard.cards.cv_desc'|trans({}, 'messages', currentLocale) }}</p>
                    <a class="btn btn-outline-primary btn-sm align-self-start" href="{{ path('admin_cv_index') }}">{{ 'app.nav.cv_admin'|trans({}, 'messages', currentLocale) }}</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h2 class="h6">{{ 'dashboard.cards.security_title'|trans({}, 'messages', currentLocale) }}</h2>
                    <p class="text-muted small flex-grow-1">{{ 'dashboard.cards.security_desc'|trans({}, 'messages', currentLocale) }}</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-outline-primary btn-sm" href="{{ path('admin_users_index') }}">{{ 'app.nav.security_users'|trans({}, 'messages', currentLocale) }}</a>
                        <a class="btn btn-outline-secondary btn-sm" href="{{ path('admin_users_invite') }}">{{ 'app.nav.security_invite'|trans({}, 'messages', currentLocale) }}</a>
                        <a class="btn btn-outline-dark btn-sm" href="{{ path('admin_bug_reports_index') }}">{{ 'app.nav.bug_reports'|trans({}, 'messages', currentLocale) }}</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h2 class="h6">{{ 'dashboard.cards.custom_quick_tiles_title'|trans({}, 'messages', currentLocale) }}</h2>
                    <p class="text-muted small flex-grow-1">{{ 'dashboard.cards.custom_quick_tiles_desc'|trans({}, 'messages', currentLocale) }}</p>
                    <a class="btn btn-outline-primary btn-sm align-self-start" href="{{ path('app_dashboard_customization_home', {panel: 'custom_quick_tiles'}) }}">{{ 'dashboard.customization_quick_tiles.title'|trans({}, 'messages', currentLocale) }}</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <h2 class="h6">{{ 'dashboard.cards.customization_backup_title'|trans({}, 'messages', currentLocale) }}</h2>
                    <p class="text-muted small flex-grow-1">{{ 'dashboard.cards.customization_backup_desc'|trans({}, 'messages', currentLocale) }}</p>
                    <a class="btn btn-outline-primary btn-sm align-self-start" href="{{ path('app_dashboard_customization_backup') }}">{{ 'dashboard.customization_backup.menu.label'|trans({}, 'messages', currentLocale) }}</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
