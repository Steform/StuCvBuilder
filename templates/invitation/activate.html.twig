{% extends 'base.html.twig' %}
{% set seoRobots = 'noindex, nofollow' %}

{% block title %}{{ 'invite.activate.meta.title'|trans }}{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-12 col-md-7 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3">{{ 'invite.activate.title'|trans }}</h1>
                    <p class="text-muted">{{ 'invite.activate.subtitle'|trans }}</p>

                    <form method="post" action="{{ path('invite_activate_submit', {token: token}) }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token(csrfActivate) }}">
                        <div class="mb-3">
                            <label for="password" class="form-label">{{ 'invite.activate.password'|trans }}</label>
                            <input id="password" name="password" type="password" class="form-control" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">{{ 'invite.activate.submit'|trans }}</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
