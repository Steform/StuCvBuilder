{% extends 'base.html.twig' %}
{% set seoRobots = 'noindex, nofollow' %}

{% block title %}{{ 'setup.meta.title'|trans }}{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-12 col-md-7 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3">{{ 'setup.title'|trans }}</h1>
                    <p class="text-muted">{{ 'setup.subtitle'|trans }}</p>

                    <form method="post" action="{{ path('setup_create_admin') }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('setup_create') }}">
                        <div class="mb-3">
                            <label for="email" class="form-label">{{ 'setup.email'|trans }}</label>
                            <input id="email" name="email" type="email" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label for="pseudonym" class="form-label">{{ 'setup.pseudonym'|trans }}</label>
                            <input id="pseudonym" name="pseudonym" type="text" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label for="password" class="form-label">{{ 'setup.password'|trans }}</label>
                            <input id="password" name="password" type="password" class="form-control" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">{{ 'setup.submit'|trans }}</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
