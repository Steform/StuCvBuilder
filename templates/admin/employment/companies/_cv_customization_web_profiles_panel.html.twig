{% set currentLocale = currentLocale|default(app.request.locale|default('fr')) %}
{% if not cvWebProfilesCustomizationEnabled|default(false) %}
    <p class="text-muted">{{ 'employment.companies.cv_customization.web_profiles.inherited_intro'|trans({}, 'messages', currentLocale) }}</p>
    <div class="d-flex flex-wrap gap-2">
        <form method="post" action="{{ cvWebProfilesFormAction }}">
            <input type="hidden" name="form_scope" value="company_cv_web_profiles_enable">
            <input type="hidden" name="customization_section" value="web_profiles">
            <input type="hidden" name="_token" value="{{ csrf_token('employment_company_cv_web_profiles_enable') }}">
            <button type="submit" class="btn btn-primary btn-sm">{{ 'employment.companies.cv_customization.web_profiles.actions.enable'|trans({}, 'messages', currentLocale) }}</button>
        </form>
        <a class="btn btn-outline-secondary btn-sm" href="{{ path('admin_cv_index', { tab: 'web_profiles' }) }}">{{ 'employment.companies.cv_customization.web_profiles.actions.edit_default'|trans({}, 'messages', currentLocale) }}</a>
    </div>
{% else %}
    {% include 'components/cv/admin/_web_profiles_customization.html.twig' with {
        currentLocale: currentLocale,
        activeLocales: activeLocales,
        defaultLocale: defaultLocale,
        cvCustomizationActivePanel: cvCustomizationActivePanel,
        cvWebProfilesEntries: cvWebProfilesEntries,
        cvWebProfilesBackgroundTexture: cvWebProfilesBackgroundTexture,
        cvWebProfilesHideSectionCustomization: cvWebProfilesHideSectionCustomization,
        cvWebProfilesFormAction: cvWebProfilesFormAction,
        cvWebProfilesFormScope: cvWebProfilesFormScope,
        cvWebProfilesCsrfTokenId: cvWebProfilesCsrfTokenId,
        cvWebProfilesCustomizationSection: cvWebProfilesCustomizationSection,
    } only %}
{% endif %}
