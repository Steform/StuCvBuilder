{% set currentLocale = currentLocale|default(app.request.locale|default('fr')) %}

{% if not cvAboutCustomizationEnabled|default(false) %}
    <div class="employment-company-cv-customization__about-inherited">
        <p class="text-muted">{{ 'employment.companies.cv_customization.about.inherited_intro'|trans({}, 'messages', currentLocale) }}</p>

        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="small text-muted mb-2">{{ 'dashboard.customization_cv.about_profile_photo.preview_alt'|trans({}, 'messages', currentLocale) }}</div>
                <img class="img-fluid rounded border" src="{{ asset(cvAboutInheritedSummaryPhotoPath|default(profilePhotoPlaceholderPath)) }}" alt="{{ 'dashboard.customization_cv.about_profile_photo.preview_alt'|trans({}, 'messages', currentLocale) }}">
            </div>
            <div class="col-md-8">
                <p class="small text-muted mb-1">{{ 'employment.companies.cv_customization.about.inherited_preview_label'|trans({}, 'messages', currentLocale) }}</p>
                {% set inheritedLocales = cvAboutInheritedPresentation.htmlByLocale|default({}) %}
                {% set previewLocale = defaultLocale|default('fr') %}
                {% set inheritedPreviewText = inheritedLocales[previewLocale]|default('')|striptags %}
                <div class="border rounded p-2 bg-body-secondary small employment-company-cv-customization__inherited-html-preview">
                    {{ inheritedPreviewText|slice(0, 280) }}{% if inheritedPreviewText|length > 280 %}…{% endif %}
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <form method="post" action="{{ cvAboutFormAction }}">
                <input type="hidden" name="form_scope" value="company_cv_about_enable">
                <input type="hidden" name="customization_section" value="about">
                <input type="hidden" name="_token" value="{{ csrf_token(cvAboutCsrfTokenIdEnable|default('employment_company_cv_about_enable')) }}">
                <button type="submit" class="btn btn-primary btn-sm">{{ 'employment.companies.cv_customization.about.actions.enable'|trans({}, 'messages', currentLocale) }}</button>
            </form>
            <a class="btn btn-outline-secondary btn-sm" href="{{ path('admin_cv_index', { tab: 'about' }) }}">
                {{ 'employment.companies.cv_customization.about.actions.edit_default'|trans({}, 'messages', currentLocale) }}
            </a>
        </div>
    </div>
{% else %}
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <span class="badge text-bg-primary">{{ 'employment.companies.cv_customization.badge.customized'|trans({}, 'messages', currentLocale) }}</span>
        <form method="post" action="{{ cvAboutFormAction }}" onsubmit="return confirm('{{ 'employment.companies.cv_customization.about.reset.confirm'|trans({}, 'messages', currentLocale)|e('js') }}');">
            <input type="hidden" name="form_scope" value="company_cv_about_reset">
            <input type="hidden" name="customization_section" value="about">
            <input type="hidden" name="_token" value="{{ csrf_token(cvAboutCsrfTokenIdReset|default('employment_company_cv_about_reset')) }}">
            <button type="submit" class="btn btn-outline-danger btn-sm">{{ 'employment.companies.cv_customization.about.actions.reset'|trans({}, 'messages', currentLocale) }}</button>
        </form>
    </div>

    {% include 'components/cv/admin/_about_customization.html.twig' with {
        currentLocale: currentLocale,
        activeLocales: activeLocales,
        defaultLocale: defaultLocale,
        cvCustomizationActivePanel: cvCustomizationActivePanel,
        cvCustomizationActiveLocale: cvCustomizationActiveLocale,
        cvAboutPresentation: cvAboutPresentation,
        cvAboutPresentationTypographyForm: cvAboutPresentationTypographyForm,
        cvAboutSectionPattern: cvAboutSectionPattern,
        cvAboutPatternTemplateLeftSvg: cvAboutPatternTemplateLeftSvg,
        cvAboutPatternTemplateRightSvg: cvAboutPatternTemplateRightSvg,
        cvAboutPatternTemplatesBySide: cvAboutPatternTemplatesBySide,
        cvAboutPatternAllowedColors: cvAboutPatternAllowedColors,
        cvAboutPatternWarnings: cvAboutPatternWarnings,
        cvAboutProfilePhotoPath: cvAboutProfilePhotoPath,
        cvAboutProfilePhotoHasUserUpload: cvAboutProfilePhotoHasUserUpload|default(false),
        profilePhotoPlaceholderPath: profilePhotoPlaceholderPath,
        cvEditorPlaceholderUiJson: cvEditorPlaceholderUiJson,
        cvAboutFormAction: cvAboutFormAction,
        cvAboutFormScope: cvAboutFormScope,
        cvAboutCsrfTokenId: cvAboutCsrfTokenId,
        cvAboutPreviewByLocale: cvAboutPreviewByLocale|default({}),
    } only %}
{% endif %}
