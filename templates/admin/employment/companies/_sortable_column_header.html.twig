{# Sortable column header for employment companies list. Requires columnKey, label, listingQuery, sortCycle, currentSort, currentSortDir. #}
{% set columnState = currentSort == columnKey ? currentSortDir : '' %}
{% set columnCycle = sortCycle[columnState] %}
<th scope="col" class="{{ thClass|default('') }}" aria-sort="{{ columnCycle.ariaSort }}">
    <a
        class="btn btn-link btn-sm p-0 text-decoration-none {{ linkClass|default('') }}"
        href="{{ path('admin_employment_companies_index', listingQuery|merge({
            sort: columnCycle.dir == '' ? null : columnKey,
            dir: columnCycle.dir == '' ? null : columnCycle.dir,
            page: null,
        })) }}"
    >
        {{ label }}
        <i class="bi {{ columnCycle.icon }} ms-1" aria-hidden="true"></i>
        <span class="visually-hidden">{{ columnCycle.labelKey|trans({}, 'messages', currentLocale) }}</span>
    </a>
</th>
