{# Optional recruiter contact fields. Requires fieldPrefix (create|edit). #}
<div class="mb-3">
    <label class="form-label" for="employment-company-{{ fieldPrefix }}-recruiter-name">{{ 'employment.companies.fields.recruiter_name'|trans({}, 'messages', currentLocale) }}</label>
    <input
        class="form-control"
        id="employment-company-{{ fieldPrefix }}-recruiter-name"
        type="text"
        name="recruiter_name"
        maxlength="255"
        {% if fieldPrefix == 'edit' %}data-employment-company-recruiter-name-input{% endif %}
    >
</div>
<fieldset class="mb-3">
    <legend class="form-label fs-6 mb-2">{{ 'employment.companies.form.address_section'|trans({}, 'messages', currentLocale) }}</legend>
    <div class="mb-3">
        <label class="form-label" for="employment-company-{{ fieldPrefix }}-address-line1">{{ 'employment.companies.fields.address_line1'|trans({}, 'messages', currentLocale) }}</label>
        <input
            class="form-control"
            id="employment-company-{{ fieldPrefix }}-address-line1"
            type="text"
            name="address_line1"
            maxlength="255"
            autocomplete="address-line1"
            {% if fieldPrefix == 'edit' %}data-employment-company-address-line1-input{% endif %}
        >
    </div>
    <div class="mb-3">
        <label class="form-label" for="employment-company-{{ fieldPrefix }}-address-line2">{{ 'employment.companies.fields.address_line2'|trans({}, 'messages', currentLocale) }}</label>
        <input
            class="form-control"
            id="employment-company-{{ fieldPrefix }}-address-line2"
            type="text"
            name="address_line2"
            maxlength="255"
            autocomplete="address-line2"
            {% if fieldPrefix == 'edit' %}data-employment-company-address-line2-input{% endif %}
        >
    </div>
    <div class="row g-2">
        <div class="col-12 col-md-4">
            <label class="form-label" for="employment-company-{{ fieldPrefix }}-address-postal-code">{{ 'employment.companies.fields.address_postal_code'|trans({}, 'messages', currentLocale) }}</label>
            <input
                class="form-control"
                id="employment-company-{{ fieldPrefix }}-address-postal-code"
                type="text"
                name="address_postal_code"
                maxlength="32"
                autocomplete="postal-code"
                {% if fieldPrefix == 'edit' %}data-employment-company-address-postal-code-input{% endif %}
            >
        </div>
        <div class="col-12 col-md-8">
            <label class="form-label" for="employment-company-{{ fieldPrefix }}-address-city">{{ 'employment.companies.fields.address_city'|trans({}, 'messages', currentLocale) }}</label>
            <input
                class="form-control"
                id="employment-company-{{ fieldPrefix }}-address-city"
                type="text"
                name="address_city"
                maxlength="128"
                autocomplete="address-level2"
                {% if fieldPrefix == 'edit' %}data-employment-company-address-city-input{% endif %}
            >
        </div>
    </div>
</fieldset>
<div class="mb-3">
    <label class="form-label" for="employment-company-{{ fieldPrefix }}-phone">{{ 'employment.companies.fields.phone'|trans({}, 'messages', currentLocale) }}</label>
    <input
        class="form-control"
        id="employment-company-{{ fieldPrefix }}-phone"
        type="tel"
        name="phone"
        maxlength="64"
        autocomplete="tel"
        {% if fieldPrefix == 'edit' %}data-employment-company-phone-input{% endif %}
    >
</div>
<div class="mb-0">
    <label class="form-label" for="employment-company-{{ fieldPrefix }}-email">{{ 'employment.companies.fields.email'|trans({}, 'messages', currentLocale) }}</label>
    <input
        class="form-control"
        id="employment-company-{{ fieldPrefix }}-email"
        type="email"
        name="email"
        maxlength="255"
        autocomplete="email"
        {% if fieldPrefix == 'edit' %}data-employment-company-email-input{% endif %}
    >
</div>
