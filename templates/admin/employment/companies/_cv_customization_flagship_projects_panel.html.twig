{% set currentLocale = currentLocale|default(app.request.locale|default('fr')) %}
{% set inheritedSummary = cvFlagshipProjectsInheritedSummary|default({}) %}
{% set sampleTitles = inheritedSummary.sampleTitles|default([]) %}

{% if not cvFlagshipProjectsCustomizationEnabled|default(false) %}
    <div class="employment-company-cv-customization__flagship-inherited">
        <p class="text-muted">{{ 'employment.companies.cv_customization.flagship_projects.inherited_intro'|trans({}, 'messages', currentLocale) }}</p>

        <div class="border rounded p-3 bg-body-secondary small mb-3 employment-company-cv-customization__inherited-flagship-preview">
            <p class="mb-2">
                <span class="text-muted">{{ 'employment.companies.cv_customization.flagship_projects.inherited_section_enabled'|trans({}, 'messages', currentLocale) }} :</span>
                {% if inheritedSummary.sectionEnabled|default(true) %}
                    <span class="badge text-bg-success">{{ 'employment.companies.cv_customization.flagship_projects.inherited_section_on'|trans({}, 'messages', currentLocale) }}</span>
                {% else %}
                    <span class="badge text-bg-secondary">{{ 'employment.companies.cv_customization.flagship_projects.inherited_section_off'|trans({}, 'messages', currentLocale) }}</span>
                {% endif %}
            </p>

            {% if inheritedSummary.projectCount|default(0) == 0 %}
                <p class="text-muted mb-0">{{ 'employment.companies.cv_customization.flagship_projects.inherited_empty'|trans({}, 'messages', currentLocale) }}</p>
            {% else %}
                <p class="mb-2">
                    {{ 'employment.companies.cv_customization.flagship_projects.inherited_counts'|trans({
                        '%count%': inheritedSummary.projectCount|default(0),
                    }, 'messages', currentLocale) }}
                </p>
                {% if sampleTitles is not empty %}
                    <ul class="mb-0 ps-3">
                        {% for title in sampleTitles %}
                            <li class="mb-1">{{ title }}</li>
                        {% endfor %}
                    </ul>
                {% endif %}
                {% if inheritedSummary.projectCount|default(0) > sampleTitles|length %}
                    <p class="text-muted small mb-0 mt-2">{{ 'employment.companies.cv_customization.flagship_projects.inherited_more'|trans({
                        '%count%': inheritedSummary.projectCount|default(0) - sampleTitles|length,
                    }, 'messages', currentLocale) }}</p>
                {% endif %}
            {% endif %}
        </div>

        <div class="d-flex flex-wrap gap-2">
            <form method="post" action="{{ cvFlagshipProjectsFormAction }}">
                <input type="hidden" name="form_scope" value="company_cv_flagship_projects_enable">
                <input type="hidden" name="customization_section" value="flagship_projects">
                <input type="hidden" name="_token" value="{{ csrf_token(cvFlagshipProjectsCsrfTokenIdEnable|default('employment_company_cv_flagship_projects_enable')) }}">
                <button type="submit" class="btn btn-primary btn-sm">{{ 'employment.companies.cv_customization.flagship_projects.actions.enable'|trans({}, 'messages', currentLocale) }}</button>
            </form>
            <a class="btn btn-outline-secondary btn-sm" href="{{ path('admin_cv_index', { tab: 'flagship_projects' }) }}">
                {{ 'employment.companies.cv_customization.flagship_projects.actions.edit_default'|trans({}, 'messages', currentLocale) }}
            </a>
        </div>
    </div>
{% else %}
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <span class="badge text-bg-primary">{{ 'employment.companies.cv_customization.badge.customized'|trans({}, 'messages', currentLocale) }}</span>
        <form method="post" action="{{ cvFlagshipProjectsFormAction }}" onsubmit="return confirm('{{ 'employment.companies.cv_customization.flagship_projects.reset.confirm'|trans({}, 'messages', currentLocale)|e('js') }}');">
            <input type="hidden" name="form_scope" value="company_cv_flagship_projects_reset">
            <input type="hidden" name="customization_section" value="flagship_projects">
            <input type="hidden" name="_token" value="{{ csrf_token(cvFlagshipProjectsCsrfTokenIdReset|default('employment_company_cv_flagship_projects_reset')) }}">
            <button type="submit" class="btn btn-outline-danger btn-sm">{{ 'employment.companies.cv_customization.flagship_projects.actions.reset'|trans({}, 'messages', currentLocale) }}</button>
        </form>
    </div>

    {% include 'components/cv/admin/_flagship_project_customization.html.twig' with {
        currentLocale: currentLocale,
        activeLocales: activeLocales,
        defaultLocale: defaultLocale,
        cvFlagshipProjectsSectionEnabled: cvFlagshipProjectsSectionEnabled,
        cvFlagshipProjectsCanonical: cvFlagshipProjectsCanonical,
        cvFlagshipProjectsMaxCount: cvFlagshipProjectsMaxCount,
        cvFlagshipProjectsFormAction: cvFlagshipProjectsFormAction,
        cvFlagshipProjectsFormScope: cvFlagshipProjectsFormScope,
        cvFlagshipProjectsCsrfTokenId: cvFlagshipProjectsCsrfTokenId,
        cvFlagshipProjectsCustomizationSection: cvFlagshipProjectsCustomizationSection,
    } only %}
{% endif %}
