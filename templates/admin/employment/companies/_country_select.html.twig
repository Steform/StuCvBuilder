{# Country select with inline add button. Requires selectId and employmentCountries. #}
<div class="employment-companies-country-select d-flex gap-2 align-items-start">
    <select class="form-select" id="{{ selectId }}" name="country_code" data-employment-country-select data-employment-company-country-input>
        <option value="">{{ 'employment.companies.fields.country_empty'|trans({}, 'messages', currentLocale) }}</option>
        {% for country in employmentCountries %}
            <option value="{{ country.code }}">{{ country.label }}</option>
        {% endfor %}
    </select>
    <button
        type="button"
        class="btn btn-outline-secondary flex-shrink-0"
        data-bs-toggle="modal"
        data-bs-target="#employmentCountryAddModal"
        data-employment-country-add-trigger
        aria-label="{{ 'employment.companies.actions.add_country_aria'|trans({}, 'messages', currentLocale) }}"
        title="{{ 'employment.companies.actions.add_country_aria'|trans({}, 'messages', currentLocale) }}"
    >
        <i class="bi bi-plus-lg" aria-hidden="true"></i>
    </button>
</div>
