{% set currentLocale = currentLocale|default(app.request.locale|default('fr')) %}
{% set inheritedEntries = cvLanguagesInheritedEntries|default([]) %}
{% if not cvLanguagesCustomizationEnabled|default(false) %}
    <div class="employment-company-cv-customization__languages-inherited">
        <p class="text-muted">{{ 'employment.companies.cv_customization.languages.inherited_intro'|trans({}, 'messages', currentLocale) }}</p>
        {% if inheritedEntries is empty %}
            <p class="text-muted">{{ 'employment.companies.cv_customization.languages.inherited_empty'|trans({}, 'messages', currentLocale) }}</p>
        {% endif %}
        <div class="d-flex flex-wrap gap-2">
            <form method="post" action="{{ cvLanguagesFormAction }}">
                <input type="hidden" name="form_scope" value="company_cv_languages_enable">
                <input type="hidden" name="customization_section" value="languages">
                <input type="hidden" name="_token" value="{{ csrf_token('employment_company_cv_languages_enable') }}">
                <button type="submit" class="btn btn-primary btn-sm">{{ 'employment.companies.cv_customization.languages.actions.enable'|trans({}, 'messages', currentLocale) }}</button>
            </form>
            <a class="btn btn-outline-secondary btn-sm" href="{{ path('admin_cv_index', { tab: 'languages' }) }}">{{ 'employment.companies.cv_customization.languages.actions.edit_default'|trans({}, 'messages', currentLocale) }}</a>
        </div>
    </div>
{% else %}
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <span class="badge text-bg-primary">{{ 'employment.companies.cv_customization.badge.customized'|trans({}, 'messages', currentLocale) }}</span>
        <form method="post" action="{{ cvLanguagesFormAction }}" onsubmit="return confirm('{{ 'employment.companies.cv_customization.languages.reset.confirm'|trans({}, 'messages', currentLocale)|e('js') }}');">
            <input type="hidden" name="form_scope" value="company_cv_languages_reset">
            <input type="hidden" name="customization_section" value="languages">
            <input type="hidden" name="_token" value="{{ csrf_token('employment_company_cv_languages_reset') }}">
            <button type="submit" class="btn btn-outline-danger btn-sm">{{ 'employment.companies.cv_customization.languages.actions.reset'|trans({}, 'messages', currentLocale) }}</button>
        </form>
    </div>
    {% include 'components/cv/admin/_languages_customization.html.twig' with {
        currentLocale: currentLocale,
        activeLocales: activeLocales,
        defaultLocale: defaultLocale,
        cvCustomizationActivePanel: cvCustomizationActivePanel,
        cvLanguagesEntries: cvLanguagesEntries,
        cvLanguagesPreviewEntries: cvLanguagesPreviewEntries|default([]),
        cvLanguagesBackgroundTexture: cvLanguagesBackgroundTexture,
        cvLanguagesHideSectionCustomization: cvLanguagesHideSectionCustomization,
        cvLanguagesFormAction: cvLanguagesFormAction,
        cvLanguagesFormScope: cvLanguagesFormScope,
        cvLanguagesCsrfTokenId: cvLanguagesCsrfTokenId,
        cvLanguagesCustomizationSection: cvLanguagesCustomizationSection,
    } only %}
{% endif %}
